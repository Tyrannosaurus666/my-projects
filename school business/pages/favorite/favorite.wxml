<view class="page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="goods-list" wx:else>
    <view class="goods-item" wx:for="{{favorites}}" wx:key="goodsId"
      bindtap="goDetail" data-id="{{item.goodsId}}">
      <image wx:if="{{item.image}}" class="goods-image" src="{{item.image}}" mode="aspectFill" />
      <view wx:else class="goods-image placehold" />
      <view class="goods-info">
        <text class="goods-title">{{item.title}}</text>
        <text class="goods-price">¥{{item.price}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{favorites.length === 0}}">
      <text>还没有收藏的商品</text>
    </view>
  </view>
</view>
