.page {
  min-height: 100vh;
  background: #f5f5f5;
}
.search-bar {
  margin: 20rpx 20rpx 0;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-placeholder {
  color: #999;
  font-size: 28rpx;
}
.banner-swiper {
  height: 280rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.category-scroll {
  white-space: nowrap;
  padding: 20rpx;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}
.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  margin-right: 20rpx;
}
.category-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #f0f9f4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}
.category-emoji {
  font-size: 40rpx;
}
.category-name {
  font-size: 22rpx;
  color: #333;
}
.goods-section {
  padding: 0 20rpx 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}
.goods-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.goods-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 0;
}
.goods-image {
  width: 100%;
  height: 350rpx;
  background: #f0f0f0;
}
.goods-info {
  padding: 16rpx;
}
.goods-title {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}
.goods-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.goods-price {
  font-size: 32rpx;
  color: #f56c6c;
  font-weight: 600;
}
.goods-campus {
  font-size: 22rpx;
  color: #999;
}
.skeleton {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 20rpx 20rpx;
}
.skeleton-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.skeleton-image {
  width: 100%;
  height: 350rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.skeleton-line {
  height: 28rpx;
  margin: 16rpx 16rpx 0;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.skeleton-line.w-60 { width: 60%; }
.skeleton-line.w-40 { width: 40%; margin-bottom: 16rpx; }
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.loading, .empty, .loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
  width: 100%;
}
