.page {
  min-height: 100vh;
  padding: 20rpx;
}
.goods-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.goods-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.goods-image {
  width: 100%;
  height: 350rpx;
  background: #f0f0f0;
}
.goods-info {
  padding: 16rpx;
}
.goods-title {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.goods-price {
  font-size: 32rpx;
  color: #f56c6c;
  font-weight: 600;
  margin-top: 8rpx;
}
.loading, .empty {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
  width: 100%;
}
