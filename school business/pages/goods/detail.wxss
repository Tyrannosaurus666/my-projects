.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}
.image-swiper {
  height: 750rpx;
  position: relative;
}
.image-swiper image {
  width: 100%;
  height: 100%;
}
.sold-tag, .off-tag {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  z-index: 10;
}
.sold-tag {
  background: rgba(0,0,0,0.6);
}
.off-tag {
  background: rgba(245,108,108,0.8);
}
.goods-info {
  padding: 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
}
.price {
  font-size: 48rpx;
  color: #f56c6c;
  font-weight: 700;
}
.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}
.title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-top: 16rpx;
}
.tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
.tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}
.desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-top: 20rpx;
  line-height: 1.6;
}
.seller-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}
.seller-card-simple {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #f9f9f9;
  margin-bottom: 0;
}
.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.seller-meta {
  flex: 1;
}
.seller-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
}
.seller-info {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}
.contact-hint {
  font-size: 26rpx;
  color: #07c160;
}
.seller-actions {
  display: flex;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}
.s-action {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #07c160;
}
.s-action + .s-action {
  border-left: 2rpx solid #f0f0f0;
}
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  gap: 20rpx;
}
.action {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.favorite {
  background: #f5f5f5;
  color: #333;
}
.favorite.active {
  background: #fef0f0;
  color: #f56c6c;
}
.contact {
  background: #07c160;
  color: #fff;
}
.report-bar {
  text-align: center;
  padding: 20rpx;
  color: #ccc;
  font-size: 24rpx;
}
.loading {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}
