<view class="page">
  <view class="form">
    <view class="form-section avatar-section">
      <text class="section-label">头像</text>
      <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" bindtap="chooseAvatar" />
      <text class="avatar-hint">点击更换头像</text>
    </view>
    <view class="form-section">
      <text class="section-label">昵称 *</text>
      <input class="form-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>
    <view class="form-section">
      <text class="section-label">学校</text>
      <input class="form-input" placeholder="请输入学校名称" value="{{school}}" bindinput="onSchoolInput" />
    </view>
    <view class="form-section">
      <text class="section-label">校区</text>
      <input class="form-input" placeholder="请输入所在校区" value="{{campus}}" bindinput="onCampusInput" />
    </view>
    <view class="form-section">
      <text class="section-label">手机号</text>
      <input class="form-input" placeholder="请输入联系方式" value="{{phone}}" bindinput="onPhoneInput" type="number" maxlength="11" />
    </view>
    <button class="save-btn" type="primary" disabled="{{saving}}" bindtap="save">
      {{saving ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
