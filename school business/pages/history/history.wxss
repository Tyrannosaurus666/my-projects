.page {
  min-height: 100vh;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #f5f5f5;
}
.title {
  font-size: 28rpx;
  font-weight: 500;
}
.clear {
  font-size: 26rpx;
  color: #999;
}
.list {
  padding: 20rpx;
}
.item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  padding: 20rpx;
}
.item-image, .item-image.placehold {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.item-title {
  font-size: 28rpx;
  color: #333;
}
.item-price {
  font-size: 32rpx;
  color: #f56c6c;
  font-weight: 600;
}
.loading, .empty {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}
