.page {
  min-height: 100vh;
  padding: 20rpx;
}
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.category-item {
  width: calc(25% - 15rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  background: #fff;
  border-radius: 16rpx;
}
.category-icon, .category-icon-placehold {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: #f0f9f4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #07c160;
}
.category-name {
  font-size: 26rpx;
  color: #333;
}
.loading {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}
