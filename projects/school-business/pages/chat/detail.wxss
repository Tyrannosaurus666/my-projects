.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
.message-list {
  flex: 1;
  padding: 20rpx;
}
.goods-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.card-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.card-info {
  flex: 1;
}
.card-title {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  overflow: hidden;
}
.card-price {
  font-size: 28rpx;
  color: #f56c6c;
  font-weight: 600;
  margin-top: 4rpx;
  display: block;
}
.message-item {
  margin-bottom: 24rpx;
  display: flex;
}
.message-item.self {
  justify-content: flex-end;
}
.message-item.other {
  justify-content: flex-start;
}
.bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}
.self .bubble {
  background: #07c160;
  color: #fff;
}
.other .bubble {
  background: #fff;
  color: #333;
}
.msg-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.img-btn {
  font-size: 40rpx;
  margin-right: 12rpx;
  padding: 8rpx;
}
.msg-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #eee;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}
.send-btn {
  background: #07c160;
  color: #fff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  line-height: 72rpx;
  height: 72rpx;
  font-size: 28rpx;
}
