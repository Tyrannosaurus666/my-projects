<view class="page">
  <view class="header">
    <text class="title">浏览记录</text>
    <text class="clear" wx:if="{{history.length > 0}}" bindtap="clearHistory">清空</text>
  </view>
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="list" wx:else>
    <view class="item" wx:for="{{history}}" wx:key="id"
      bindtap="goDetail" data-id="{{item.id}}">
      <image wx:if="{{item.image}}" class="item-image" src="{{item.image}}" mode="aspectFill" />
      <view wx:else class="item-image placehold" />
      <view class="item-info">
        <text class="item-title">{{item.title}}</text>
        <text class="item-price">¥{{item.price}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{history.length === 0}}">
      <text>暂无浏览记录</text>
    </view>
  </view>
</view>
