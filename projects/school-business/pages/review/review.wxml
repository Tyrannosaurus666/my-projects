<view class="page">
  <view class="form">
    <view class="form-section">
      <text class="section-label">评分</text>
      <view class="stars">
        <text class="star {{item <= rating ? 'active' : ''}}"
          wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
          bindtap="onRatingChange" data-value="{{item}}">★</text>
      </view>
    </view>
    <view class="form-section">
      <text class="section-label">评价</text>
      <textarea class="form-textarea" placeholder="说说你对这次交易的感受..." value="{{content}}" bindinput="onContentInput" />
    </view>
    <button class="submit-btn" type="primary" disabled="{{submitting}}" bindtap="submit">
      {{submitting ? '提交中...' : '提交评价'}}
    </button>
  </view>
</view>
