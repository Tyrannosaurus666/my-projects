<view class="page">
  <view class="search-bar" bindtap="goSearch">
    <text class="search-icon">🔍</text>
    <text class="search-placeholder">搜索二手好物...</text>
  </view>
  <swiper class="banner-swiper" indicator-dots autoplay interval="3000" circular>
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item" style="background: {{index === 0 ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)' : index === 1 ? 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)' : 'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)'}}">
        <text class="banner-text">{{item.text}}</text>
      </view>
    </swiper-item>
  </swiper>
  <scroll-view class="category-scroll" scroll-x show-scrollbar="{{false}}">
    <view class="category-item" wx:for="{{categories}}" wx:key="_id"
      bindtap="goCategory" data-id="{{item._id}}" data-name="{{item.name}}">
      <view class="category-circle">
        <text class="category-emoji">{{item.name === '教材书籍' ? '📚' : item.name === '电子产品' ? '📱' : item.name === '生活用品' ? '🏠' : item.name === '服饰鞋包' ? '👗' : item.name === '运动户外' ? '⚽' : item.name === '美妆护肤' ? '💄' : item.name === '文具办公' ? '✏️' : '📦'}}</text>
      </view>
      <text class="category-name">{{item.name}}</text>
    </view>
  </scroll-view>
  <view class="skeleton" wx:if="{{loading}}">
    <view class="skeleton-item" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton-image" />
      <view class="skeleton-line w-60" />
      <view class="skeleton-line w-40" />
    </view>
  </view>
  <view class="goods-section" wx:else>
    <text class="section-title">最新商品</text>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{goodsList}}" wx:key="_id"
        bindtap="goDetail" data-id="{{item._id}}">
        <image wx:if="{{item.images && item.images[0]}}" class="goods-image" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
        <view wx:else class="goods-image placehold" />
        <view class="goods-info">
          <text class="goods-title">{{item.title}}</text>
          <view class="goods-meta">
            <text class="goods-price">¥{{item.price}}</text>
            <text class="goods-campus" wx:if="{{item.campus}}">{{item.campus}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{goodsList.length === 0}}">
      <text>暂无商品，快来发布第一件好物吧</text>
    </view>
    <view class="loading-more" wx:if="{{hasMore && goodsList.length > 0}}">
      <text>上拉加载更多...</text>
    </view>
    <view class="loading-more" wx:if="{{!hasMore && goodsList.length > 0}}">
      <text>— 已加载全部商品 —</text>
    </view>
  </view>
</view>
