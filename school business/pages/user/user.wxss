.page {
  min-height: 100vh;
}
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
  background: linear-gradient(180deg, #07c160 0%, #e8f8ee 100%);
}
.default-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
}
.login-text {
  margin-top: 24rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}
.login-desc {
  margin-top: 12rpx;
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
}
.user-header {
  display: flex;
  align-items: center;
  padding: 80rpx 30rpx 60rpx;
  background: linear-gradient(180deg, #07c160 0%, #e8f8ee 100%);
  position: relative;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.user-meta {
  flex: 1;
  overflow: hidden;
}
.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.info-row {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}
.info-label {
  font-size: 24rpx;
  color: #666;
}
.credit {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
.edit-icon {
  position: absolute;
  right: 30rpx;
  top: 80rpx;
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 8rpx;
}
.menu-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
}
.menu-item:last-child {
  border-bottom: none;
}
.arrow {
  color: #ccc;
  font-size: 36rpx;
}
.logout-btn {
  margin: 40rpx 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #f56c6c;
}
