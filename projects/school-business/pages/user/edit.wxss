.page {
  min-height: 100vh;
  padding: 20rpx;
}
.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.form-section {
  margin-bottom: 30rpx;
}
.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin: 12rpx 0;
}
.avatar-hint {
  font-size: 24rpx;
  color: #999;
}
.save-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
}
