<view class="page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="conversation-list" wx:else>
    <view class="conversation-item" wx:for="{{conversations}}" wx:key="_id"
      bindtap="goChat" data-id="{{item._id}}" data-otherid="{{item.otherId}}">
      <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="conversation-info">
        <view class="top-row">
          <text class="nickname">{{item.nickname}}</text>
          <text class="time">{{item.lastTimeStr}}</text>
        </view>
        <view class="bottom-row">
          <text class="last-msg">{{item.lastMessage}}</text>
          <view class="unread" wx:if="{{item.unreadCount > 0}}">{{item.unreadCount > 99 ? '99+' : item.unreadCount}}</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{conversations.length === 0}}">
      <text>暂无消息</text>
      <text class="empty-hint">去逛逛商品，和卖家聊聊吧</text>
    </view>
  </view>
</view>
