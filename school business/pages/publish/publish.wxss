.page {
  min-height: 100vh;
  padding: 20rpx;
}
.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.form-section {
  margin-bottom: 30rpx;
}
.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}
.section-label.required::before {
  content: '* ';
  color: #f56c6c;
}
.form-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
.form-row {
  display: flex;
  gap: 20rpx;
}
.form-half {
  flex: 1;
}
.price-input {
  display: flex;
  align-items: center;
}
.price-sign {
  font-size: 32rpx;
  color: #333;
  margin-right: 8rpx;
}
.price-input .form-input {
  flex: 1;
}
.picker {
  height: 72rpx;
  line-height: 72rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 0 20rpx;
  color: #333;
  font-size: 28rpx;
}
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.image-item, .image-upload {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
}
.image-item image {
  width: 100%;
  height: 100%;
}
.remove-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  text-align: center;
  line-height: 36rpx;
  border-radius: 50%;
  font-size: 28rpx;
}
.image-upload {
  border: 2rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}
.upload-icon {
  font-size: 48rpx;
  line-height: 1;
}
.upload-hint {
  font-size: 22rpx;
  margin-top: 4rpx;
}
.submit-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
}
